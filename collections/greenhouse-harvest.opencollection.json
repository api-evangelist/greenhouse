                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Update candidate"
        },
        {
          "info": {
            "name": "Delete candidate",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://harvest.greenhouse.io/v1/candidates/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete candidate"
        }
