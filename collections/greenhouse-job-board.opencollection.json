{
  "opencollection": "1.0.0",
  "info": {
    "name": "Greenhouse Job Board API",
    "version": "1.0"
  },
  "items": [
    {
      "info": {
        "name": "Default",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Retrieve job board",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://boards-api.greenhouse.io/v1/boards/{board_token}/"
          },
          "docs": "Returns the organization name and job board content."
        }
      ]
    },
    {
      "info": {
        "name": "Jobs",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List job posts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://boards-api.greenhouse.io/v1/boards/{board_token}/jobs",
            "params": [
              {
                "name": "content",
                "value": "",
                "type": "query",
                "description": "Include full descriptions when true."
              }
            ]
          },
          "docs": "List job posts"
        },
        {
          "info": {
            "name": "Retrieve job",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://boards-api.greenhouse.io/v1/boards/{board_token}/jobs/:job_id",
            "params": [
              {
                "name": "job_id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve job"
        },
        {
          "info": {
            "name": "Submit application",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://boards-api.greenhouse.io/v1/boards/{board_token}/jobs/:job_id",
            "params": [
              {
                "name": "job_id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "basic",
              "username": "{{username}}",
              "password": "{{password}}"
            }
          },
          "docs": "Submit a job application using multipart form-data or JSON."
        }
      ]
    },
